# Bloquear acceso HTTP directo a los scripts utilitarios.
# Sólo deben ejecutarse desde la línea de comandos (CLI), nunca vía Apache.
# Compatible con Apache 2.2 y 2.4.

<IfModule mod_authz_core.c>
    Require all denied
</IfModule>

<IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
</IfModule>
